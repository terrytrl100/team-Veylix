# Veylix web — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# WalletConnect / Reown Cloud project id (free): https://cloud.reown.com
# Required for the WalletConnect QR / mobile connect flow. Injected browser
# wallets (e.g. MetaMask) work without it.
NEXT_PUBLIC_WC_PROJECT_ID=

# Set to "true" to include the Sepolia testnet in the chain list.
NEXT_PUBLIC_ENABLE_TESTNETS=false
